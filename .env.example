# Database
DATABASE_URL=postgresql://user:password@localhost:5432/human_service

# Auth
SERVICE_API_KEY=your-service-api-key

# Port
PORT=3000

# Runs service (cost tracking)
RUNS_SERVICE_URL=https://runs.mcpfactory.org
RUNS_SERVICE_API_KEY=

# Key service (BYOK key resolution)
KEY_SERVICE_URL=https://key.mcpfactory.org
KEY_SERVICE_API_KEY=

# API Registry
API_REGISTRY_URL=https://api-registry.mcpfactory.org
API_REGISTRY_API_KEY=

# Firecrawl (optional, falls back to direct fetch)
FIRECRAWL_API_KEY=

# Anthropic (for AI extraction)
ANTHROPIC_API_KEY=

# Content generation service (alternative to direct Anthropic)
CONTENT_GENERATION_SERVICE_URL=
CONTENT_GENERATION_SERVICE_API_KEY=
