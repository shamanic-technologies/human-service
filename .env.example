# Database (Neon Postgres)
HUMAN_SERVICE_DATABASE_URL=postgresql://user:password@localhost:5432/human_service

# Service-to-service auth
HUMAN_SERVICE_API_KEY=your-service-api-key

# Runs service (cost tracking)
RUNS_SERVICE_URL=https://runs.mcpfactory.org
RUNS_SERVICE_API_KEY=

# Key service (API key resolution)
KEY_SERVICE_URL=https://key.mcpfactory.org
KEY_SERVICE_API_KEY=

# Scraping service
SCRAPING_SERVICE_URL=https://scraping.distribute.you
SCRAPING_SERVICE_API_KEY=

# CRM service (lead provider — a client's uploaded contact list; serves a
# CRM-sourced audience via serve-next). Read at call time; fails the request
# loudly if absent (ProviderConfigError → 502).
CRM_SERVICE_URL=https://crm.mcpfactory.org
CRM_SERVICE_API_KEY=
